# Your Discord Bot Token
DISCORD_TOKEN=YOUR_BOT_TOKEN_HERE

# IDs of the categories where new ticket channels should be created
SUPPORT_CATEGORY_ID=123456789012345678
GIVEAWAY_CATEGORY_ID=123456789012345678
PARTNERSHIP_CATEGORY_ID=123456789012345678
SPAWNER_CATEGORY_ID=123456789012345678
BUILDER_CATEGORY_ID=123456789012345678

# ID of the standard role that handles tickets
TICKET_ROLE_ID=123456789012345678

# ID of the higher permission role that can also manage tickets
HIGH_PERMS_ROLE_ID=123456789012345678

# ImgBB API Key for saving ticket images
IMGBB_API_KEY=your_imgbb_api_key_here

# Channel ID where transcripts will be sent
TRANSCRIPT_CHANNEL_ID=123456789012345678

# Toggle whether to ping staff when a new ticket opens (true/false)
PING_STAFF=true

# Ticket Panel Display Settings (Use \n for new lines)
TICKET_PANEL_TITLE="🎫 Support Tickets"
TICKET_PANEL_TEXT="**Pick the category that fits your reason for opening a ticket — staff will respond when they're free.**\n\n🆘 **__Support__**\nQuestions, concerns, server issues, account problems, or anything else that needs staff attention.\n> State your issue clearly when the ticket opens. **Don't ping staff** — wait and someone will respond.\n\n🤝 **__Technical Support__**\nOpen a ticket if you need technical support!\n\n🎉 **__Giveaway Claim__**\nIf you would like to claim a giveaway you won, open a ticket from the giveaway you won. If it doesn't work open a support ticket.\n\n📜 **__Ticket rules__**\n• One open ticket at a time\n• Don't ping staff or builders\n• Troll / fake tickets = blacklist\n\n> Pick a category from the buttons below to open your ticket."

# Channels for new Vouch and Proof systems
VOUCH_CHANNEL_ID=123456789012345678
GIVEAWAY_PROOF_CHANNEL_ID=123456789012345678

# AI Configuration (Gemini)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.5-flash

# Toggle AI partnership generation (1 = enabled, 0 = disabled)
ENABLE_AI=0

# If AI is disabled, you can provide custom thresholds using JSON.
# Example format: [{"max": 75, "we": "Nothing", "you": "@everyone"}, {"max": 300, "we": "Nothing", "you": "@Member"}]
PARTNERSHIP_RANGES=[{"max": 75, "label": "0-75", "we": "Nothing", "you": "@Member"}, {"max": 150, "label": "75-150", "we": "@partner", "you": "@Member"}, {"max": 250, "label": "150-250", "we": "@Member", "you": "@Member"}, {"max": 999999, "label": "250+", "we": "your requirements", "you": ""}]

# Ban system
# Channel ID where banned members can read and appeal their ban
BAN_APPEAL_CHANNEL_ID=123456789012345678
# Role ID that gets assigned when a member is banned (should deny access to all channels)
# This role also acts as the Scammer role — it is removed on unban
BANNED_ROLE_ID=123456789012345678

# Role to ping when a tracked TikTok account goes live
LIVE_PING_ROLE_ID=123456789012345678

# Channel ID where staff applications are sent for review
APPLICATION_REVIEW_CHANNEL_ID=123456789012345678
